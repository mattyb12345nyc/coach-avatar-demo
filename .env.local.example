# LiveAvatar (HeyGen) — server-side only
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=75b46fd5-554d-4f3f-876d-3210c906443b
LIVEAVATAR_API_URL=https://api.liveavatar.com
NEXT_PUBLIC_LIVEAVATAR_API_URL=https://api.liveavatar.com

# Default avatar persona (optional)
LIVEAVATAR_VOICE_ID=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_LANGUAGE=en

# Anthropic — server-side only, used by /api/score
ANTHROPIC_API_KEY=

# Optional: override scoring endpoint. Leave blank to use this app's
# built-in /api/score route. Setting this to a fully-qualified URL
# (e.g. https://coach.futureproof.work/.netlify/functions/anthropic-proxy)
# would only work if that endpoint allows CORS from this origin and
# does not require auth — coach-connect's proxy currently does both,
# so the local /api/score route is the only path that ships in this demo.
NEXT_PUBLIC_SCORING_ENDPOINT=
